# Marco configuration file
# Place in ~/.config/marco/marco.toml or ./marco.toml

[colors]
bg = "default"         # Background color (default uses terminal background)
fg = "white"           # Foreground color for entries
highlight_fg = "black" # Foreground color for selected entry
highlight_bg = "cyan"  # Background color for selected entry

# Available colors: black, red, green, yellow, blue, magenta, cyan, white, default

padding = 2            # Left padding for entries

editor = null          # Editor command (null uses $EDITOR or $VISUAL or vi)
                       # Example: editor = "code"

[keybindings]
select = " "           # Key to toggle file selection
copy = "c"             # Key to copy selected files
cut = "x"              # Key to cut selected files
paste = "p"            # Key to paste files
page_up = "u"          # Key to scroll up half a page
page_down = "d"        # Key to scroll down half a page
quit = "q"             # Key to quit marco

# Command aliases - run on selected files when typed in shell prompt
# Use {file} as placeholder for the selected file path
[aliases]
gitadd = "git add {file}"
rm = "rm -i {file}"
mv = "mv {file}"